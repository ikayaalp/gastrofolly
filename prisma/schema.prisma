// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js modelleri
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Kullanıcı modeli
model User {
  id                        String    @id @default(cuid())
  name                      String?
  username                  String?   @unique
  email                     String    @unique
  emailVerified             DateTime?
  image                     String?
  password                  String? // Hashlenmiş şifre
  firebaseUid               String?   @unique // Firebase Authentication UID
  verificationCode          String? // 6 haneli doğrulama kodu
  verificationCodeExpiry    DateTime? // Kodun geçerlilik süresi
  resetToken                String? // Şifre sıfırlama token
  resetTokenExpiry          DateTime? // Token geçerlilik süresi
  phoneNumber               String? // Telefon numarası
  role                      UserRole  @default(STUDENT)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  subscriptionPlan          String? // "Commis", "Chef D party", "Executive"
  subscriptionBillingPeriod String? // "MONTHLY" | "SIXMONTHLY" | "YEARLY"
  subscriptionStartDate     DateTime? // Abonelik başlangıç tarihi
  subscriptionEndDate       DateTime? // Abonelik bitiş tarihi
  subscriptionReferenceCode String? // Iyzico Abonelik Referans Kodu (İptal için gerekli)
  subscriptionCancelled     Boolean   @default(false) // Abonelik iptal edildi mi (dönem sonunda silinecek)
  bio                       String? // Profil açıklaması
  coverImage                String? // Profil kapak fotoğrafı
  pushToken                 String? // Expo Push Notification token
  referralCode              String?   @unique // Fenomen referral kodu
  discountPercent           Int       @default(10) // Fenomen indirim oranı (%)
  referredBy                String? // Bu kullanıcıyı getiren fenomenin ID'si

  referredByUser User?  @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals      User[] @relation("UserReferrals")

  currentSessionId String?

  accounts         Account[]
  sessions         Session[]
  enrollments      Enrollment[]
  reviews          Review[]
  progress         Progress[]
  createdCourses   Course[]         @relation("CourseInstructor")
  payments         Payment[]
  topics           Topic[]
  posts            Post[]
  topicLikes       TopicLike[]
  postLikes        PostLike[]
  messages         Message[]
  certificates     Certificate[]
  notifications    Notification[]
  stories          Story[]
  pollVotes        PollVote[]
  referralEarnings Referral[]       @relation("InfluencerReferrals")
  referredPayments Referral[]       @relation("ReferredUserReferrals")
  aiConversations  AiConversation[]
  followers        Follow[]         @relation("UserFollowing")
  following        Follow[]         @relation("UserFollowers")
  financeRecords   FinanceRecord[]
  conversationParticipants ConversationParticipant[]
  sentDirectMessages       DirectMessage[]
  savedTopics              SavedTopic[]
  reportsMade              Report[]
  blocks                   Block[]          @relation("Blocker")
  blockedBy                Block[]          @relation("Blocked")
  instructorPayouts        InstructorPayout[]
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
  INFLUENCER
}

// Kategori modeli
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  slug        String   @unique
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]
}

// Kurs modeli
model Course {
  id                String      @id @default(cuid())
  title             String
  description       String
  price             Float
  isFree            Boolean     @default(false)
  discountRate      Float? // İndirim oranı (0-100 arası)
  discountedPrice   Float? // İndirimli fiyat (otomatik hesaplanır)
  accessibleByPlans String[]    @default([]) // "COMMIS", "CHEF_DE_PARTIE", "EXECUTIVE"
  imageUrl          String? // Yatay (1.45:1) kart görseli
  thumbnailImageUrl String? // Kare (1:1) küçük thumbnail/ikon görseli
  posterImageUrl    String? // Dikey (2:3) poster/öne çıkan kart görseli
  detailImageUrl    String? // Kurs detay sayfası banner görseli (opsiyonel, panelden ayarlanır)
  level             CourseLevel @default(BEGINNER)
  duration          Int? // dakika cinsinden
  isPublished       Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  instructorId String
  instructor   User     @relation("CourseInstructor", fields: [instructorId], references: [id])
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  lessons      Lesson[]
  enrollments  Enrollment[]
  reviews      Review[]
  progress     Progress[]
  payments     Payment[]
  messages     Message[]
  certificates Certificate[]
  stories      Story[]

  homeSectionCourses HomeSectionCourse[]
  homeCovers         HomeCover[]
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Ders modeli
model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  pdfUrl      String?
  duration    Int? // dakika cinsinden
  order       Int
  isFree      Boolean  @default(false)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progress Progress[]
}

// Kayıt modeli
model Enrollment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// İlerleme modeli
model Progress {
  id          String   @id @default(cuid())
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  watchedAt   DateTime @default(now())
  timeWatched Int      @default(0) // İzlenen süre (saniye cinsinden)

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// Değerlendirme modeli
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Ödeme modeli
model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  platform        PaymentPlatform?
  stripePaymentId String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId           String
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String?
  course           Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subscriptionPlan String? // Abonelik ödemesi ise plan adı
  billingPeriod    String? // "monthly" or "yearly"
  discountCode     String? // Kullanılan indirim kodu
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentPlatform {
  IYZICO
  REVENUECAT_APPLE
  REVENUECAT_GOOGLE
  STRIPE
}

model InstructorPayout {
  id            String   @id @default(cuid())
  instructorId  String
  instructor    User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  month         Int      // e.g. 7 (for July)
  year          Int      // e.g. 2026
  poolShare     Float    // Calculated amount to pay
  totalMinutes  Int      // Instructor's total minutes watched in that month
  percentage    Float    // Instructor's percentage of the pool
  status        String   @default("PENDING") // PENDING, PAID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([instructorId, month, year])
}

// İndirim Kodu modeli
model DiscountCode {
  id            String   @id @default(cuid())
  code          String   @unique
  discountType  String // "PERCENTAGE" or "FIXED"
  discountValue Float // 20 for 20% or 50 for 50₺
  validFrom     DateTime
  validUntil    DateTime
  maxUses       Int? // null = unlimited
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Fenomen Referral Komisyon modeli
model Referral {
  id             String   @id @default(cuid())
  influencerId   String
  referredUserId String
  paymentId      String?
  amount         Float // Ödeme tutarı
  commission     Float // Kazanılan komisyon (%10)
  createdAt      DateTime @default(now())

  influencer   User @relation("InfluencerReferrals", fields: [influencerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferredUserReferrals", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@index([referredUserId])
}

// Forum Kategori modeli
model ForumCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  slug        String   @unique
  color       String?  @default("#f97316")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics Topic[]
}

// Forum Başlık modeli
model Topic {
  id           String   @id @default(cuid())
  title        String
  content      String
  slug         String   @unique
  isPinned     Boolean  @default(false)
  isLocked     Boolean  @default(false)
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  mediaUrl     String? // Eklenen medya URL'i (Cloudinary)
  mediaType    String? // "IMAGE" veya "VIDEO"
  thumbnailUrl String? // Video için önizleme görseli
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])

  posts     Post[]
  likes     TopicLike[]
  hashtags  Hashtag[]   @relation("TopicHashtags")
  savedBy   SavedTopic[]
  reports   Report[]

  poll Poll?

  @@index([createdAt])
  @@index([likeCount])
  @@index([categoryId, createdAt])
}

// Anket Modeli
model Poll {
  id        String   @id @default(cuid())
  question  String
  startDate DateTime @default(now())
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId String @unique
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id   String @id @default(cuid())
  text String

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes PollVote[]
}

model PollVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([userId, pollId])
}

// Forum Hashtag modeli
model Hashtag {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "yemektarifleri"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics Topic[] @relation("TopicHashtags")
}

// Forum Beğeni modeli
model TopicLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

// Forum Mesaj modeli
model Post {
  id           String   @id @default(cuid())
  content      String
  likeCount    Int      @default(0)
  parentId     String?
  mediaUrl     String? // Eklenen medya URL'i (Cloudinary)
  mediaType    String? // "IMAGE" veya "VIDEO"
  thumbnailUrl String? // Video için önizleme görseli
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  parent  Post?      @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Post[]     @relation("PostReplies")
  likes   PostLike[]
  reports Report[]
}

// Forum Yorum Beğeni modeli
model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// Mesaj modeli (Eğitmen-Öğrenci iletişimi)
model Message {
  id        String   @id @default(cuid())
  content   String
  parentId  String? // Yanıt mesajı için
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  parent  Message?  @relation("MessageReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Message[] @relation("MessageReplies")
}

// Sertifika modeli
model Certificate {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  courseName String
  issuedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// Bildirim modeli
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String?
  topicId  String?
  postId   String?

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  NEW_COURSE
  COURSE_UPDATE
  SYSTEM
  FORUM_REPLY
  FORUM_MENTION
  FORUM_LIKE
}

// Hikaye Modeli
model Story {
  id        String   @id @default(cuid())
  mediaUrl  String // Resim veya Video URL
  mediaType String // "IMAGE" veya "VIDEO"
  duration  Int      @default(5000) // Ms cinsinden süre
  createdAt DateTime @default(now())
  expiresAt DateTime // Hikayenin yayından kalkacağı zaman

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  title      String? // Hikaye başlığı
  coverImage String? // Hikaye kapak resmi URL
  order      Int      @default(0)
}

// Culi AI Sohbet modeli
model AiConversation {
  id        String      @id @default(cuid())
  title     String      @default("Yeni Sohbet")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  role           String
  content        String         @db.Text
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// Takip Modeli
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ==========================================
// DIRECT MESSAGING (DM) MODELS
// ==========================================

model Conversation {
  id            String                    @id @default(cuid())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  lastMessageAt DateTime?

  participants  ConversationParticipant[]
  messages      DirectMessage[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Abonelik Planlari
model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  price           Float
  interval        String   @default("monthly")
  iyzicoPlanCode  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Finans Kayıtları (Gelir/Gider)
model FinanceRecord {
  id          String      @id @default(cuid())
  type        FinanceType // INCOME or EXPENSE
  amount      Float
  title       String
  description String?
  category    String?     // Opsiyonel kategori (Örn: Maaş, Reklam, Hosting)
  documentUrl String?     // Fatura resmi (optional)
  date        DateTime    // Gelir/Gider tarihi
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

enum FinanceType {
  INCOME
  EXPENSE
}

// ============================================================
// Anasayfa (/home) yönetimi — admin panelinden düzenlenir
// ============================================================

// Hero (kapak) slaytları. Kayıt yoksa /home öne çıkan kurs görsellerine düşer.
model HomeCover {
  id        String   @id @default(cuid())
  imageUrl  String // Mobil kare görsel
  webImageUrl String? // Web geniş banner görseli
  title     String? // Slayt üzerindeki başlık (opsiyonel)
  subtitle  String? // Alt başlık (opsiyonel)
  linkUrl   String? // "Kursa Başla" butonunun gideceği yer (opsiyonel)
  courseId  String? // Direkt uygulama içi native kurs yönlendirmesi için (opsiyonel)
  course    Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// "Eğitmenlerimiz" satırı. Kayıt yoksa /home gerçek INSTRUCTOR kullanıcılarına düşer.
// Panelden oluşturulan her kayıt, arkada gerçek bir User (role=INSTRUCTOR) hesabıyla eşleşir.
model HomeInstructor {
  id        String   @id @default(cuid())
  name      String
  subtitle  String? // Örn: "Michelin Yıldızlı Şef" (yoksa yıldız/kurs bilgisi gösterilmez)
  imageUrl  String?
  linkUrl   String? // Tıklanınca gidilecek yer (boşsa /instructor/{userId})
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  userId    String?  @unique // Bağlı gerçek eğitmen hesabı (User.id)
  email     String? // Bağlı hesabın e-postası (panelde göstermek için, denormalize)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// /home bölümlerinin sırası ve görünürlüğü. key sabit bir bölüm anahtarıdır.
model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique // "continue" | "stories" | "featured" | "popular" | "instructors" | "recent" | "categories"
  label     String // Panelde gösterilen okunabilir ad
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  updatedAt DateTime @updatedAt

  isCustom  Boolean  @default(false)
  courses   HomeSectionCourse[]
}

model HomeSectionCourse {
  id            String      @id @default(cuid())
  homeSectionId String
  homeSection   HomeSection @relation(fields: [homeSectionId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order         Int         @default(0)

  @@unique([homeSectionId, courseId])
}

// Webhook idempotency kaydı. Stripe/Iyzico/RevenueCat webhook'ları aynı olayı
// birden fazla kez gönderebilir (retry) — bu tablo her olayı bir kez işlemeyi
// garanti eder (dedupeKey unique, ilk create kazanır, ikinci P2002 alır).
model WebhookEvent {
  id        String   @id @default(cuid())
  source    String // "stripe" | "iyzico" | "revenuecat"
  dedupeKey String   @unique
  createdAt DateTime @default(now())
}

// ============================================================
// New Features: SavedTopic, Report, Block
// ============================================================

model SavedTopic {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model Report {
  id          String   @id @default(cuid())
  reason      String   // e.g. "Spam", "Inappropriate", etc.
  description String?
  status      String   @default("PENDING") // "PENDING", "REVIEWED_DISMISSED", "REVIEWED_REMOVED"
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporterId  String
  reporter    User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  topicId     String?
  topic       Topic? @relation(fields: [topicId], references: [id], onDelete: Cascade)

  postId      String?
  post        Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Block {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerId String
  blocker   User   @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  
  blockedId String
  blocked   User   @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}
